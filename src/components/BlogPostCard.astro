---
interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/blog/${slug}`} class="group block">
  <article class="py-6 border-b border-[var(--color-border)] transition-all duration-300 hover:pl-4">
    <div class="flex items-baseline gap-4 mb-1.5">
      <time
        class="text-xs font-mono text-[var(--color-text-tertiary)] shrink-0"
        datetime={date.toISOString()}
      >
        {formattedDate}
      </time>
      <div class="h-px flex-1 bg-[var(--color-border)] group-hover:bg-[var(--color-accent)]/30 transition-colors duration-300"></div>
    </div>
    <h3
      class="font-display font-semibold text-xl text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors duration-200"
    >
      {title}
      <span class="inline-block ml-2 text-sm opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">&rarr;</span>
    </h3>
    <p class="text-sm text-[var(--color-text-secondary)] mt-1 leading-relaxed">
      {description}
    </p>
  </article>
</a>

<style>
  html.dark article {
    border-color: var(--color-dark-border);
  }
  html.dark h3 {
    color: var(--color-dark-text);
  }
  html.dark .group:hover h3 {
    color: var(--color-accent);
  }
  html.dark time {
    color: var(--color-dark-text-tertiary);
  }
  html.dark p {
    color: var(--color-dark-text-secondary);
  }
  html.dark .h-px {
    background-color: var(--color-dark-border);
  }
</style>
