---
interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/blog/${slug}`} class="group block no-underline">
  <article class="py-5 border-b border-[var(--color-border-warm)] dark:border-[var(--color-border-night)] transition-colors">
    <time
      class="text-sm font-mono text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)]"
      datetime={date.toISOString()}
    >
      {formattedDate}
    </time>
    <h3
      class="font-serif text-xl mt-1 mb-1.5 text-[var(--color-ink)] dark:text-[var(--color-paper)] group-hover:text-[var(--color-terracotta)] dark:group-hover:text-[var(--color-terracotta-light)] transition-colors"
    >
      {title}
      <span class="inline-block ml-1 text-sm opacity-0 group-hover:opacity-100 transition-opacity">&rarr;</span>
    </h3>
    <p class="text-sm text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)] leading-relaxed">
      {description}
    </p>
  </article>
</a>
