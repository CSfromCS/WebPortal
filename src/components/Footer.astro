---
import { redirects } from "../data/redirects";

const year = new Date().getFullYear();
---

<footer class="w-full max-w-5xl mx-auto px-5 sm:px-8 py-8 mt-16 border-t border-[var(--color-border)] transition-colors">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs font-mono text-[var(--color-text-tertiary)]">
    <p>&copy; {year} Christian Sarabia</p>
    <div class="flex items-center gap-4">
      <a
        href={redirects.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[var(--color-coral)] transition-colors"
      >
        GitHub
      </a>
      <span class="text-[var(--color-border)]">/</span>
      <a
        href={redirects.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[var(--color-coral)] transition-colors"
      >
        LinkedIn
      </a>
      <span class="text-[var(--color-border)]">/</span>
      <a
        href="mailto:hello@christiansarabia.com"
        class="hover:text-[var(--color-coral)] transition-colors"
      >
        Email
      </a>
    </div>
  </div>
</footer>

<style>
  html.light footer {
    border-color: var(--color-light-border);
    color: var(--color-light-text-tertiary);
  }
</style>
