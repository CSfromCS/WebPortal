---
const year = new Date().getFullYear();
---

<footer
  class="w-full max-w-3xl mx-auto px-6 py-10 mt-16 border-t border-[var(--color-border-warm)] dark:border-[var(--color-border-night)] transition-colors"
>
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)]">
    <p>&copy; {year} Christian Sarabia</p>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com/CSfromCS"
        target="_blank"
        rel="noopener noreferrer"
        class="no-underline hover:text-[var(--color-ink)] dark:hover:text-[var(--color-paper)] transition-colors"
      >
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/PLACEHOLDER"
        target="_blank"
        rel="noopener noreferrer"
        class="no-underline hover:text-[var(--color-ink)] dark:hover:text-[var(--color-paper)] transition-colors"
      >
        LinkedIn
      </a>
    </div>
  </div>
</footer>
