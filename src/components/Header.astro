---
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
  { href: "/now", label: "Now" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[var(--color-cream)]/80 dark:bg-[var(--color-night)]/80 border-b border-[var(--color-border-warm)] dark:border-[var(--color-border-night)] transition-colors duration-300"
>
  <nav class="max-w-3xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="font-serif text-xl tracking-tight no-underline hover:text-[var(--color-terracotta)] dark:hover:text-[var(--color-terracotta-light)] transition-colors"
    >
      CS
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-7">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm tracking-wide no-underline relative py-1 transition-colors duration-200",
              isActive(link.href)
                ? "text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)]"
                : "text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)] hover:text-[var(--color-ink)] dark:hover:text-[var(--color-paper)]",
            ]}
          >
            {link.label}
            {isActive(link.href) && (
              <span class="absolute bottom-0 left-0 w-full h-px bg-[var(--color-terracotta)] dark:bg-[var(--color-terracotta-light)]" />
            )}
          </a>
        ))
      }
      <ThemeToggle />
    </div>

    <!-- Mobile Controls -->
    <div class="flex md:hidden items-center gap-2">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open menu"
        class="w-9 h-9 flex items-center justify-center rounded-full transition-colors hover:bg-[var(--color-cream-dark)] dark:hover:bg-[var(--color-night-raised)]"
      >
        <svg
          class="w-5 h-5"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <line x1="4" y1="7" x2="20" y2="7" stroke-linecap="round"></line>
          <line x1="4" y1="12" x2="20" y2="12" stroke-linecap="round"></line>
          <line x1="4" y1="17" x2="20" y2="17" stroke-linecap="round"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav Panel -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-[var(--color-border-warm)] dark:border-[var(--color-border-night)] bg-[var(--color-cream)]/95 dark:bg-[var(--color-night)]/95 backdrop-blur-md"
  >
    <div class="px-6 py-4 flex flex-col gap-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-base py-1 no-underline transition-colors",
              isActive(link.href)
                ? "text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)]"
                : "text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)]",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  btn.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });
</script>
