---
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
  { href: "/now", label: "Now" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-[var(--color-void)]/70 border-b border-[var(--color-border)] transition-colors duration-300"
>
  <nav class="max-w-5xl mx-auto px-5 sm:px-8 h-14 flex items-center justify-between">
    <!-- Logo mark -->
    <a href="/" class="group flex items-center gap-2">
      <span class="font-display font-bold text-lg tracking-tight group-hover:text-[var(--color-accent)] transition-colors duration-200">
        CS
      </span>
      <span class="hidden sm:inline text-xs font-mono text-[var(--color-text-tertiary)]">
        /christian
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm px-3 py-1.5 rounded-md transition-all duration-200",
              isActive(link.href)
                ? "text-[var(--color-accent)] bg-[var(--color-accent)]/10"
                : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-raised)]",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <div class="ml-2 pl-2 border-l border-[var(--color-border)]">
        <ThemeToggle />
      </div>
    </div>

    <!-- Mobile Controls -->
    <div class="flex md:hidden items-center gap-1">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Toggle menu"
        class="w-9 h-9 flex items-center justify-center rounded-full transition-colors hover:bg-[var(--color-surface-raised)]"
      >
        <div class="hamburger-icon flex flex-col gap-[5px]">
          <span class="block w-4 h-[1.5px] bg-current transition-all duration-300 origin-center"></span>
          <span class="block w-4 h-[1.5px] bg-current transition-all duration-300"></span>
          <span class="block w-3 h-[1.5px] bg-current transition-all duration-300 origin-center"></span>
        </div>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav Panel -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-[var(--color-surface)] border-t border-[var(--color-border)]"
  >
    <div class="px-5 py-4 flex flex-col gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-base py-2 px-3 rounded-md transition-all duration-200",
              isActive(link.href)
                ? "text-[var(--color-accent)] bg-[var(--color-accent)]/10"
                : "text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-raised)]",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<style>
  html.dark header {
    background-color: rgba(10, 10, 11, 0.7);
    border-color: var(--color-dark-border);
  }
  html.dark .hamburger-icon span {
    background: var(--color-dark-text);
  }
  html.dark #mobile-menu {
    background-color: var(--color-dark-surface);
    border-color: var(--color-dark-border);
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  btn.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });
</script>
