---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const num = String(index + 1).padStart(2, "0");
---

<article
  class="reveal group relative p-6 sm:p-8 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/50 transition-all duration-500 hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-surface)]"
  style={`transition-delay: ${index * 0.08}s`}
>
  <!-- Number accent -->
  <span class="absolute -top-3 -left-1 sm:-left-2 font-display font-bold text-5xl sm:text-6xl text-[var(--color-accent)]/10 group-hover:text-[var(--color-accent)]/20 transition-colors duration-500 select-none pointer-events-none">
    {num}
  </span>

  <!-- Header -->
  <div class="relative mb-4">
    <h3 class="font-display font-semibold text-xl sm:text-2xl leading-tight text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors duration-300">
      {project.link ? (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2"
        >
          {project.title}
          <svg class="w-4 h-4 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </a>
      ) : (
        project.title
      )}
    </h3>
    <div class="flex items-center gap-2 mt-2">
      <span class="text-xs font-mono text-[var(--color-accent)]">{project.role}</span>
      <span class="text-[var(--color-text-tertiary)]">&middot;</span>
      <span class="text-xs font-mono text-[var(--color-text-tertiary)]">{project.period}</span>
    </div>
  </div>

  <!-- Description -->
  <p class="text-[var(--color-text-secondary)] mb-5 leading-relaxed">
    {project.description}
  </p>

  <!-- Highlights -->
  {project.highlights.length > 0 && (
    <ul class="mb-5 space-y-2">
      {project.highlights.map((item) => (
        <li class="text-sm text-[var(--color-text-secondary)] flex gap-2.5">
          <span class="text-[var(--color-accent)] mt-1.5 shrink-0 w-1 h-1 rounded-full bg-[var(--color-accent)]"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  )}

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {project.tags.map((tag) => (
      <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-1 rounded-md bg-[var(--color-surface-raised)] text-[var(--color-text-tertiary)] border border-[var(--color-border)] group-hover:border-[var(--color-amber)]/45 group-hover:text-[var(--color-amber)] transition-colors">
        {tag}
      </span>
    ))}
  </div>
</article>

<style>
  html.dark article {
    background-color: rgba(20, 20, 22, 0.5);
    border-color: var(--color-dark-border);
  }
  html.dark article:hover {
    background-color: var(--color-dark-surface);
    border-color: rgba(45, 140, 78, 0.4);
  }
  html.dark h3 {
    color: var(--color-dark-text);
  }
  html.dark .group:hover h3 {
    color: var(--color-accent);
  }
  html.dark p, html.dark li span:last-child {
    color: var(--color-dark-text-secondary);
  }
  html.dark span[class*="font-mono"][class*="text-\\[var\\(--color-text-tertiary\\)\\]"] {
    color: var(--color-dark-text-tertiary);
  }
  html.dark span[class*="bg-\\[var\\(--color-surface-raised\\)\\]"] {
    background-color: var(--color-dark-surface-raised);
    border-color: var(--color-dark-border);
  }
</style>
