---
import BaseLayout from "../layouts/BaseLayout.astro";

const skills = [
  "Python", "C++", "C#", "SQL", "NoSQL", "Java", "JavaScript", "R",
  "PowerBI", "Tableau", "Excel", "Power Query",
  "Transformers", "XGBoost", "YOLOv8", "NLP",
  "Azure", "Docker", "Figma", "Raspberry Pi", "Arduino",
  "Agile", "Scrum", "ITIL",
];

const interests = [
  "Photography", "Mountaineering", "Urban Development", "Philosophy",
  "Education", "Perfumes", "Running", "Chess", "Guitar",
];
---

<BaseLayout title="About" description="The fuller story.">
  <section class="py-8 md:py-12">
    <h1 class="font-serif text-4xl md:text-5xl tracking-tight mb-12">About</h1>

    <!-- Who -->
    <div class="mb-14">
      <p class="text-lg leading-relaxed mb-4">
        I'm a 24-year-old Filipino software engineer living in Melbourne, Australia.
        Originally from Novaliches, Philippines.
      </p>
      <p class="text-lg leading-relaxed">
        I work at <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)]">Microsoft Azure</span> (L60),
        scaling cloud infrastructure across 400+ datacenters. Before that, I studied Computer Science at
        Ateneo de Manila University and spent time at Citi and in the competitive programming world.
      </p>
    </div>

    <!-- Education -->
    <div class="mb-14">
      <h2 class="font-serif text-2xl mb-6 text-[var(--color-ink)] dark:text-[var(--color-paper)]">Education</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-serif text-xl">Ateneo de Manila University</h3>
          <p class="text-sm text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)] mt-1">
            B.S. Computer Science (Hons), Minor in Data Science & Analytics &middot; 2020&ndash;2024
          </p>
          <ul class="mt-3 space-y-2 text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)]">
            <li class="flex gap-2">
              <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
              GPA: 3.94/4.0 &mdash; Rank 1 in program, Summa Cum Laude
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
              St. Ignatius Award &mdash; Most Outstanding Scholar (highest university honor): excellence in academics, extra-curriculars, and service
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
              3 Full Scholarships: Ateneo Full-ride, National DOST-SEI Merit, Director's List (Top 2%)
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
              CAPM Certified (PMI, Sep 2023)
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Competitions & Recognition -->
    <div class="mb-14">
      <h2 class="font-serif text-2xl mb-6 text-[var(--color-ink)] dark:text-[var(--color-paper)]">Competitions & Recognition</h2>
      <ul class="space-y-2 text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)]">
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          ICPC 2021 &mdash; Highest Ranking Philippine Team (International Collegiate Programming Contest)
        </li>
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          Google HackFest 2023 &mdash; Grand Champion
        </li>
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          P&G Next 8 (Feb 2023) &mdash; Selected as one of the Top 8 prospective IT Manager graduates in the Philippines
        </li>
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          CS Summit 5.0 Ideathon &mdash; 1st Runner-up + MDI Novare Award
        </li>
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          Ateneo Junior Summer Seminar (AJSS 52.2) &mdash; Invited as top ACET scorer nationwide
        </li>
      </ul>
    </div>

    <!-- Leadership & Community -->
    <div class="mb-14">
      <h2 class="font-serif text-2xl mb-6 text-[var(--color-ink)] dark:text-[var(--color-paper)]">Leadership & Community</h2>
      <ul class="space-y-2 text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)]">
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          <span><strong class="text-[var(--color-ink)] dark:text-[var(--color-paper)] font-medium">Ateneo CODE</strong> &mdash; Project Head, OrgDev Consultant. Provided consultancy services to 60+ youth organisations nationwide.</span>
        </li>
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          <span><strong class="text-[var(--color-ink)] dark:text-[var(--color-paper)] font-medium">ICPC Manila 2022</strong> &mdash; Secretariat Head</span>
        </li>
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          <span><strong class="text-[var(--color-ink)] dark:text-[var(--color-paper)] font-medium">Ateneo Summer Programming Camp</strong> &mdash; Head Secretariat & Tutor (introducing high schoolers to competitive programming)</span>
        </li>
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          <span><strong class="text-[var(--color-ink)] dark:text-[var(--color-paper)] font-medium">PinoyTech Victoria</strong> &mdash; Digital Transformation Consultant, Core Team. Branding, client interaction, cybersecurity education, tech mentorship.</span>
        </li>
        <li class="flex gap-2">
          <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] shrink-0">&bull;</span>
          <span><strong class="text-[var(--color-ink)] dark:text-[var(--color-paper)] font-medium">Filipino Community Council of Victoria Inc.</strong> &mdash; Community Volunteer</span>
        </li>
      </ul>
    </div>

    <!-- Technical Skills -->
    <div class="mb-14">
      <h2 class="font-serif text-2xl mb-6 text-[var(--color-ink)] dark:text-[var(--color-paper)]">Technical Skills</h2>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class="text-xs font-mono px-2.5 py-1 rounded-full bg-[var(--color-cream-dark)] dark:bg-[var(--color-night-raised)] text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)] border border-[var(--color-border-warm)] dark:border-[var(--color-border-night)]">
            {skill}
          </span>
        ))}
      </div>
    </div>

    <!-- Interests -->
    <div class="mb-8">
      <h2 class="font-serif text-2xl mb-4 text-[var(--color-ink)] dark:text-[var(--color-paper)]">Interests</h2>
      <p class="text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)] leading-relaxed">
        {interests.join(" · ")}
      </p>
    </div>
  </section>
</BaseLayout>
