---
import BaseLayout from "../layouts/BaseLayout.astro";

const credentials = {
  education: [
    "B.S. Computer Science (Hons), Minor in Data Science & Analytics — Ateneo de Manila University",
    "GPA: 3.94/4.0 | Rank 1 | Summa Cum Laude | St. Ignatius Award",
    "3 full scholarships: Ateneo Full-ride, National DOST-SEI Merit, Director's List (Top 2%)",
    "CAPM Certified (PMI, 2023)",
  ],
  notable: [
    "ICPC 2021 — Highest-ranking Philippine team",
    "Google HackFest 2023 — Grand Champion (built Refind in 2 days)",
    "P&G Next 8 — Selected as one of the top 8 IT graduates in the Philippines",
    "University thesis on Transformer-based transit prediction — accepted for oral presentation in Macau",
  ],
  community: [
    "PinoyTech Victoria — Digital Transformation Consultant, Core Team",
    "Ateneo CODE — Consultancy for 60+ youth organisations nationwide",
    "ICPC Manila 2022 — Secretariat Head",
    "Filipino Community Council of Victoria — Volunteer, Driver, Host",
  ],
};
---

<BaseLayout title="About" description="The fuller story.">
  <section class="py-8 md:py-12">
    <!-- Header -->
    <div class="mb-16 reveal">
      <span class="text-xs font-mono uppercase tracking-widest text-[var(--color-accent)] mb-3 block">Background</span>
      <h1 class="font-display font-bold text-4xl md:text-6xl tracking-tight mb-4">About</h1>
    </div>

    <!-- Résumé version -->
    <div class="mb-12 reveal">
      <div class="max-w-2xl space-y-4 text-lg leading-relaxed">
        <p>
          I'm Christian Sarabia — a Filipino software engineer based in Melbourne, Australia.
        </p>
        <p class="text-[var(--color-text-secondary)]">
          I grew up in Novaliches in the Philippines, went through UP Integrated School, and studied Computer Science at
          Ateneo de Manila University, where I graduated Summa Cum Laude, Rank 1, with the St. Ignatius Award — the
          university's highest honour for academics, service, and character. I moved to Melbourne in mid-2024 and started
          at Microsoft the following February.
        </p>
      </div>
    </div>

    <!-- The turn -->
    <div class="mb-12 reveal">
      <div class="max-w-2xl space-y-4 text-lg leading-relaxed">
        <p class="font-medium text-[var(--color-text-primary)]">
          That's the résumé version. Here's the real one.
        </p>
        <p class="text-[var(--color-text-secondary)]">
          Moving to Melbourne meant leaving behind a life that was full — friends everywhere, orgs I'd built with people
          I loved, a campus where I knew every corner. What I got in exchange was a good career and a quiet apartment. So
          the question I've been working on since isn't about professional growth. It's about how to build a life that
          feels as rich as the one I left.
        </p>
      </div>
    </div>

    <!-- Community -->
    <div class="mb-12 reveal">
      <div class="max-w-2xl space-y-4 text-lg leading-relaxed">
        <p class="text-[var(--color-text-secondary)]">
          That's why community work isn't a side thing for me.
          <span class="text-[var(--color-amber)] font-medium">PinoyTech Victoria</span>, the Filipino Community Council,
          mentoring — these aren't extracurriculars. They're how I stay connected to what I care about. In the Philippines,
          I spent four years at <span class="text-[var(--color-amber)] font-medium">Ateneo CODE</span> consulting for
          youth organisations, facilitated nationwide events, tutored high schoolers in competitive programming, and helped
          run ICPC Manila. That instinct — build something, bring people in, make it work — is just how I operate.
        </p>
      </div>
    </div>

    <!-- Professional identity -->
    <div class="mb-12 reveal">
      <div class="max-w-2xl space-y-4 text-lg leading-relaxed">
        <p class="text-[var(--color-text-secondary)]">
          Professionally, I'm a systems thinker. I like understanding how things fit together, finding the leverage points,
          and building solutions that hold up at scale. At Microsoft I do that with cloud infrastructure. Outside of work
          I do it with communities and side projects.
        </p>
      </div>
    </div>

    <!-- Interests -->
    <div class="mb-20 reveal">
      <div class="max-w-2xl space-y-4 text-lg leading-relaxed">
        <p class="text-[var(--color-text-secondary)]">
          I'm interested in a lot of things — AI, personal finance, running, perfumes, photography, philosophy, urban
          development. I don't think interests need to justify themselves. Some of them will turn into something. Most of
          them just make life more interesting.
        </p>
      </div>
    </div>

    <!-- The drawer -->
    <div class="reveal">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="font-display font-semibold text-2xl">The Drawer</h2>
        <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      </div>
      <p class="text-[var(--color-text-secondary)] text-lg mb-10 max-w-2xl">
        If you want the full credentials, here's what's in the drawer.
      </p>

      <!-- Education -->
      <div class="mb-10">
        <h3 class="font-display font-medium text-lg mb-4 text-[var(--color-accent)]">Education</h3>
        <div class="space-y-2">
          {credentials.education.map((item) => (
            <div class="flex gap-2.5 text-sm text-[var(--color-text-secondary)]">
              <span class="w-1 h-1 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Notable -->
      <div class="mb-10">
        <h3 class="font-display font-medium text-lg mb-4 text-[var(--color-accent)]">Notable</h3>
        <div class="space-y-2">
          {credentials.notable.map((item) => (
            <div class="flex gap-2.5 text-sm text-[var(--color-text-secondary)]">
              <span class="w-1 h-1 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Community -->
      <div class="mb-8">
        <h3 class="font-display font-medium text-lg mb-4 text-[var(--color-accent)]">Community</h3>
        <div class="space-y-2">
          {credentials.community.map((item) => (
            <div class="flex gap-2.5 text-sm text-[var(--color-text-secondary)]">
              <span class="w-1 h-1 rounded-full bg-[var(--color-amber)] mt-2 shrink-0"></span>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  html.dark .text-\[var\(--color-text-secondary\)\] {
    color: var(--color-dark-text-secondary);
  }
  html.dark .text-\[var\(--color-text-primary\)\] {
    color: var(--color-dark-text);
  }
  html.dark .h-px {
    background-color: var(--color-dark-border);
  }
</style>
