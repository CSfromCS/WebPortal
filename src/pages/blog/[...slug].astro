---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="py-8 md:py-12">
    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-sm text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] transition-colors mb-10 group"
    >
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      Back to blog
    </a>

    <!-- Post Header -->
    <header class="mb-12 reveal">
      <time
        class="text-xs font-mono uppercase tracking-widest text-[var(--color-accent)]"
        datetime={post.data.date.toISOString()}
      >
        {formattedDate}
      </time>
      <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight mt-4 mb-4">
        {post.data.title}
      </h1>
      {post.data.description && (
        <p class="text-lg text-[var(--color-text-secondary)]">
          {post.data.description}
        </p>
      )}
      <div class="h-px w-16 bg-[var(--color-accent)] mt-8"></div>
    </header>

    <!-- Content -->
    <div class="prose reveal">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  html.dark time {
    color: var(--color-accent);
  }
  html.dark p {
    color: var(--color-dark-text-secondary);
  }
  html.dark a {
    color: var(--color-dark-text-tertiary);
  }
  html.dark a:hover {
    color: var(--color-accent);
  }
</style>
