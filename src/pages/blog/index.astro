---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="Thoughts, notes, and things I'm learning.">
  <section class="py-8 md:py-12">
    <div class="mb-16 reveal">
      <span class="text-xs font-mono uppercase tracking-widest text-[var(--color-coral)] mb-3 block">Writing</span>
      <h1 class="font-display font-bold text-4xl md:text-6xl tracking-tight mb-4">
        Blog
      </h1>
      <p class="text-[var(--color-text-secondary)] text-lg max-w-lg">
        Thoughts, notes, and things I'm figuring out.
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="reveal-stagger">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.id}
          />
        ))}
      </div>
    ) : (
      <div class="reveal text-center py-20">
        <p class="text-[var(--color-text-tertiary)] font-mono text-sm">
          // nothing here yet
        </p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  html.light p {
    color: var(--color-light-text-secondary);
  }
</style>
