---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="Projects" description="Things I've built and been part of.">
  <section class="py-8 md:py-12">
    <!-- Header -->
    <div class="mb-16 reveal">
      <span class="text-xs font-mono uppercase tracking-widest text-[var(--color-accent)] mb-3 block">Portfolio</span>
      <h1 class="font-display font-bold text-4xl md:text-6xl tracking-tight mb-4">
        Projects
      </h1>
      <p class="text-[var(--color-text-secondary)] text-lg max-w-lg">
        Not a full CV. Just the stories worth telling.
      </p>
    </div>

    <!-- Project list -->
    <div class="space-y-8">
      {projects.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  html.dark p {
    color: var(--color-dark-text-secondary);
  }
</style>
