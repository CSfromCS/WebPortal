---
import BaseLayout from "../layouts/BaseLayout.astro";
import { redirects } from "../data/redirects";
---

<BaseLayout title="Home" wide>
  <!-- Hero -->
  <section class="relative py-12 md:py-24 overflow-hidden">
    <!-- Background blobs -->
    <div class="blob blob-coral w-72 h-72 -top-20 -right-20 absolute"></div>
    <div class="blob blob-purple w-56 h-56 bottom-10 -left-32 absolute" style="animation-delay: -7s;"></div>

    <!-- Oversized name -->
    <div class="relative">
      <h1 class="font-display font-bold text-[clamp(3rem,10vw,7rem)] leading-[0.95] tracking-tighter mb-6">
        <span class="block animate-fade-up">Christian</span>
        <span class="block animate-fade-up text-[var(--color-accent)]" style="animation-delay: 0.1s;">Sarabia</span>
      </h1>

      <!-- One-liner (values-first, not role-first) -->
      <div class="animate-fade-up flex items-center gap-3 mb-8" style="animation-delay: 0.2s;">
        <span class="inline-block w-8 h-px bg-[var(--color-accent)]"></span>
        <span class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-secondary)]">Builder Who Bridges</span>
      </div>

      <!-- Intro -->
      <div class="max-w-xl space-y-4 text-lg leading-relaxed animate-fade-up" style="animation-delay: 0.3s;">
        <p class="font-display font-medium text-xl md:text-2xl tracking-tight leading-snug">
          I build things that work — for systems and for people.
        </p>
        <p class="text-[var(--color-text-secondary)]">
          I'm Christian, a software engineer at <span class="text-[var(--color-accent)] font-medium">Microsoft Azure</span> in Melbourne.
          I work on infrastructure that scales across 400+ datacenters — but the work I care about most is the kind that connects people.
          Whether that's building community for Filipino tech professionals in Victoria, consulting for youth organisations across the Philippines,
          or just making something small and fun to share with friends.
        </p>
      </div>
    </div>

    <!-- Social links -->
    <div class="flex flex-wrap items-center gap-4 mt-12 animate-fade-up" style="animation-delay: 0.4s;">
      <a
        href={redirects.github}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--color-border)] text-sm text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-300"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
        GitHub
      </a>
      <a
        href={redirects.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--color-border)] text-sm text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-300"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
        </svg>
        LinkedIn
      </a>
      <a
        href="mailto:cs@christiansarabia.com"
        class="group inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--color-border)] text-sm text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-300"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        Email
      </a>
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-border)] my-12 md:my-20"></div>

  <!-- Work Section -->
  <section class="reveal mb-16 md:mb-24">
    <div class="flex items-center gap-3 mb-8">
      <h2 class="font-display font-semibold text-2xl">Work</h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>
    <div class="max-w-2xl space-y-4 text-lg leading-relaxed">
      <p>
        I'm currently a Software Engineer at <span class="text-[var(--color-accent)] font-medium">Microsoft Azure</span>,
        working in C# on hardware validation — making sure the infrastructure that powers the cloud is secure and reliable
        from factory to customer. I was promoted in under a year, which is uncommon for a grad hire, and I've taken on
        project management and team leadership work alongside my engineering role.
      </p>
      <p class="text-[var(--color-text-secondary)]">
        I like building things that make complex systems simpler for the people who use them.
      </p>
    </div>
    <div class="mt-8">
      <a
        href="/projects"
        class="group inline-flex items-center gap-3 text-[var(--color-accent)] font-display font-medium text-lg hover:gap-5 transition-all duration-300"
      >
        See what I've built
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Community Section -->
  <section class="reveal mb-8">
    <div class="flex items-center gap-3 mb-8">
      <h2 class="font-display font-semibold text-2xl">Community</h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>
    <div class="max-w-2xl space-y-4 text-lg leading-relaxed">
      <p class="font-medium">
        Building things alone has never been my thing. The best work I've done has always had people at the center of it.
      </p>
      <p class="text-[var(--color-text-secondary)]">
        At <span class="text-[var(--color-amber)] font-medium">PinoyTech Victoria</span>, I help Filipino tech professionals
        find their footing in Australia — through mentorship, digital transformation consulting, and the kind of support I wish
        I had when I first moved here. Before that, I spent four years at
        <span class="text-[var(--color-amber)] font-medium">Ateneo CODE</span>, providing consultancy to over 60 youth
        organisations nationwide in the Philippines. I've been a facilitator, a logistics head, a secretariat lead — whatever
        the work needed.
      </p>
      <p class="text-[var(--color-text-secondary)]">
        I care about this because I know what it's like to build from scratch in a new place. If I can make that easier for someone else, that's the point.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  html.dark .blob {
    opacity: 0.06;
  }
  html.dark p {
    color: var(--color-dark-text);
  }
  html.dark p.text-\[var\(--color-text-secondary\)\] {
    color: var(--color-dark-text-secondary);
  }
  html.dark a[class*="border"] {
    border-color: var(--color-dark-border);
    color: var(--color-dark-text-secondary);
  }
  html.dark a[class*="border"]:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
