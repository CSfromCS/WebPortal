---
import BaseLayout from "../layouts/BaseLayout.astro";

const items = [
  { emoji: "☁️", label: "Work", text: "Settling into a recent promotion at Microsoft Azure. Navigating a new manager, taking on more leadership, and figuring out what the next chapter looks like." },
  { emoji: "🤖", label: "Building", text: "Working on Cosine — a personal AI system that helps me think, reflect, and keep track of what matters. It's part life coach, part knowledge base, part experiment in what AI can actually do for one person's life." },
  { emoji: "🇵🇭", label: "Community", text: "Active with PinoyTech Victoria, helping with digital transformation projects and mentorship for Filipino tech professionals in Melbourne." },
  { emoji: "🏃", label: "Running", text: "Training. Not fast yet, but consistent." },
  { emoji: "📚", label: "Reading/Thinking about", text: "How to build a life that compounds — not just financially, but in relationships, skills, and the kind of work that matters." },
  { emoji: "🏠", label: "Life", text: "Living in Melbourne with family. Partner is in medical school until 2027. Learning what patience looks like in practice." },
];
---

<BaseLayout title="Now" description="What I'm currently up to.">
  <section class="py-8 md:py-12">
    <div class="mb-16 reveal">
      <span class="text-xs font-mono uppercase tracking-widest text-[var(--color-accent)] mb-3 block">Status</span>
      <h1 class="font-display font-bold text-4xl md:text-6xl tracking-tight mb-4">What I'm up to right now</h1>
      <p class="text-[var(--color-text-secondary)] text-sm">
        Updated March 2026 &middot;
        <a
          href="https://nownownow.com/about"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-accent)] hover:text-[var(--color-accent-bright)] transition-colors"
        >
          What is a /now page?
        </a>
      </p>
    </div>

    <div class="reveal-stagger space-y-1">
      {items.map((item) => (
        <div class="group flex items-center gap-4 py-4 px-4 -mx-4 rounded-lg hover:bg-[var(--color-surface-raised)] transition-all duration-200">
          <span class="text-xl">{item.emoji}</span>
          <p class="text-lg"><span class="font-medium">{item.label}:</span> {item.text}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  html.dark .group:hover {
    background-color: var(--color-dark-surface);
  }
  html.dark .text-\[var\(--color-text-secondary\)\] {
    color: var(--color-dark-text-secondary);
  }
</style>
