---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Now" description="What I'm currently up to.">
  <section class="py-8 md:py-12">
    <h1 class="font-serif text-4xl md:text-5xl tracking-tight mb-4">Now</h1>
    <p class="text-[var(--color-ink-muted)] dark:text-[var(--color-paper-muted)] text-sm mb-12">
      Last updated: March 2026 &middot;
      <a
        href="https://nownownow.com/about"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)]"
      >
        What is a /now page?
      </a>
    </p>

    <div class="space-y-6 text-lg leading-relaxed">
      <div class="flex gap-3">
        <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] mt-0.5 shrink-0">&#9702;</span>
        <p>Training for a 15km race (March 29, Melbourne)</p>
      </div>
      <div class="flex gap-3">
        <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] mt-0.5 shrink-0">&#9702;</span>
        <p>Working on Azure infrastructure at Microsoft</p>
      </div>
      <div class="flex gap-3">
        <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] mt-0.5 shrink-0">&#9702;</span>
        <p>Building a personal knowledge base system</p>
      </div>
      <div class="flex gap-3">
        <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] mt-0.5 shrink-0">&#9702;</span>
        <p>Exploring perfumes</p>
      </div>
      <div class="flex gap-3">
        <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] mt-0.5 shrink-0">&#9702;</span>
        <p>Learning guitar</p>
      </div>
      <div class="flex gap-3">
        <span class="text-[var(--color-terracotta)] dark:text-[var(--color-terracotta-light)] mt-0.5 shrink-0">&#9702;</span>
        <p>Studying Mandarin</p>
      </div>
    </div>
  </section>
</BaseLayout>
